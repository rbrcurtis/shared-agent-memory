#!/usr/bin/env bash
set -e

# ingest-transcript — Extract learnings from a Claude Code session JSONL file
# and store/update them in the shared memory daemon.

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
OLLAMA_MODEL="gemma4:26b"
OLLAMA_URL="http://localhost:11434/api/generate"
SOCKET_PATH="/tmp/shared-memory.sock"
DRY_RUN=false
PROJECT=""
FILE=""

QDRANT_URL="${QDRANT_URL:-http://localhost:6333}"
COLLECTION_NAME="${COLLECTION_NAME:-shared_agent_memory}"

# Read QDRANT_API_KEY from env, or extract from ~/.claude.json MCP config
if [[ -z "${QDRANT_API_KEY:-}" ]]; then
  QDRANT_API_KEY=$(python3 -c "
import json, os
try:
    d = json.load(open(os.path.expanduser('~/.claude.json')))
    print(d.get('mcpServers',{}).get('shared-memory',{}).get('env',{}).get('QDRANT_API_KEY',''))
except: print('')
" 2>/dev/null)
fi
QDRANT_API_KEY="${QDRANT_API_KEY:-}"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log() {
  echo "[ingest] $*" >&2
}

die() {
  echo "[ingest] ERROR: $*" >&2
  exit 1
}

# ---------------------------------------------------------------------------
# Arg parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --file)       FILE="$2";          shift 2 ;;
    --model)      OLLAMA_MODEL="$2";  shift 2 ;;
    --project)    PROJECT="$2";       shift 2 ;;
    --dry-run)    DRY_RUN=true;       shift   ;;
    *)            die "Unknown argument: $1" ;;
  esac
done

[[ -n "$FILE" ]]        || die "--file is required"
[[ -f "$FILE" ]]        || die "File not found: $FILE"

# ---------------------------------------------------------------------------
# Project auto-detection
# ---------------------------------------------------------------------------
if [[ -z "$PROJECT" ]]; then
  # Claude Code paths: ~/.claude/projects/-home-ryan-Code-myproject/session-id.jsonl
  if [[ "$FILE" =~ /projects/-[^/]+-([^/]+)/[^/]+\.jsonl$ ]]; then
    PROJECT="${BASH_REMATCH[1]}"
  else
    PROJECT="unknown"
  fi
  log "Auto-detected project: $PROJECT"
fi

# ---------------------------------------------------------------------------
# Temp files
# ---------------------------------------------------------------------------
TMP_PREFIX="/tmp/ingest-$$"
NORM_FILE="${TMP_PREFIX}-normalized.txt"
CANDIDATES_FILE="${TMP_PREFIX}-candidates.json"
DECISIONS_FILE="${TMP_PREFIX}-decisions.json"

cleanup() {
  rm -f "${TMP_PREFIX}"*
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Helper: send JSON-RPC to daemon socket via python3
# daemon_rpc <method> <params_json>
# Prints the full JSON response to stdout.
# ---------------------------------------------------------------------------
daemon_rpc() {
  local method="$1"
  local params="$2"

  python3 -c "
import socket, json, sys

sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
sock.connect(sys.argv[1])
sock.settimeout(30)

params = json.loads(sys.argv[4])
params['qdrantUrl'] = sys.argv[5]
params['qdrantApiKey'] = sys.argv[6]
params['collectionName'] = sys.argv[7]

req = json.dumps({'jsonrpc':'2.0','id':sys.argv[2],'method':sys.argv[3],'params':params}) + '\n'
sock.sendall(req.encode())

buf = b''
while b'\n' not in buf:
    chunk = sock.recv(65536)
    if not chunk:
        break
    buf += chunk

sock.close()
print(buf.decode().strip())
" "$SOCKET_PATH" "$RANDOM$RANDOM" "$method" "$params" "$QDRANT_URL" "$QDRANT_API_KEY" "$COLLECTION_NAME"
}

# ---------------------------------------------------------------------------
# Helper: call ollama HTTP API
# ollama_generate <prompt>
# Prints the response text to stdout.
# ---------------------------------------------------------------------------
ollama_generate() {
  local prompt="$1"

  local tmp_prompt="${TMP_PREFIX}-ollama-prompt.txt"
  printf '%s' "$prompt" > "$tmp_prompt"

  local tmp_response="${TMP_PREFIX}-ollama-resp.json"
  local http_code

  # Build payload with python to avoid shell escaping issues
  python3 -c "
import json, sys
prompt = open(sys.argv[1]).read()
payload = {
    'model': sys.argv[2],
    'prompt': prompt,
    'stream': False,
    'format': {
        'type': 'object',
        'properties': {
            'learnings': {
                'type': 'array',
                'items': {
                    'type': 'object',
                    'properties': {
                        'title': {'type': 'string'},
                        'text': {'type': 'string'},
                        'tags': {'type': 'array', 'items': {'type': 'string'}},
                        'action': {'type': 'string'},
                        'id': {'type': 'string'},
                        'reason': {'type': 'string'},
                    },
                    'required': ['title', 'text'],
                },
            },
        },
        'required': ['learnings'],
    },
    'options': {'num_predict': 4096, 'num_ctx': max(8192, len(prompt) * 2)},
}
with open(sys.argv[3], 'w') as f:
    json.dump(payload, f)
" "$tmp_prompt" "$OLLAMA_MODEL" "${TMP_PREFIX}-ollama-payload.json"

  http_code=$(curl -s -o "$tmp_response" -w "%{http_code}" \
    --max-time 180 \
    -X POST "$OLLAMA_URL" \
    -H "Content-Type: application/json" \
    -d @"${TMP_PREFIX}-ollama-payload.json")

  if [[ "$http_code" != "200" ]]; then
    log "Ollama returned HTTP $http_code"
    cat "$tmp_response" >&2
    return 1
  fi

  # Extract .response field, sanitize control chars
  python3 -c "
import json, sys, re
data = json.load(open(sys.argv[1]))
raw = data.get('response','')
# Strip control characters except newline
raw = re.sub(r'[\x00-\x09\x0b-\x1f]', ' ', raw)
print(raw)
" "$tmp_response"
}

# ---------------------------------------------------------------------------
# Preflight: verify daemon is reachable
# ---------------------------------------------------------------------------
log "Checking daemon at ${SOCKET_PATH}..."
PING_RESP=$(daemon_rpc "ping" "{}") || true

if ! echo "$PING_RESP" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); assert d.get('result',{}).get('pong')" 2>/dev/null; then
  die "Cannot reach daemon at ${SOCKET_PATH}. Is it running?"
fi
log "Daemon is up."

# ---------------------------------------------------------------------------
# STEP 1: Normalize transcript
# ---------------------------------------------------------------------------
log "Step 1: Normalizing transcript from $FILE..."

python3 - "$FILE" "$NORM_FILE" <<'PYEOF'
import json, sys

src = sys.argv[1]
dst = sys.argv[2]

# Signal-only filtering: keep user/assistant text, tool names, tool errors.
# Drop successful tool results (bulk content like file reads, search results).
# This preserves the full conversation signal without position-based truncation.

SKIP_PREFIXES = ('<local-command', '<command-name', 'Base directory', '<system-reminder')

lines_out = []

with open(src) as f:
    for raw in f:
        raw = raw.strip()
        if not raw:
            continue
        try:
            entry = json.loads(raw)
        except json.JSONDecodeError:
            continue

        etype = entry.get('type', '')

        if etype in ('user', 'assistant'):
            role = etype.upper()
            content = entry.get('message', {}).get('content', '')

            if isinstance(content, str):
                text = content.strip()
                if not text:
                    continue
                if any(text.startswith(p) for p in SKIP_PREFIXES):
                    continue
                lines_out.append(f"{role}: {text}")

            elif isinstance(content, list):
                for block in content:
                    btype = block.get('type', '')
                    if btype == 'text':
                        text = block.get('text', '').strip()
                        if not text:
                            continue
                        if any(text.startswith(p) for p in SKIP_PREFIXES):
                            continue
                        lines_out.append(f"{role}: {text}")
                    elif btype == 'tool_use':
                        name = block.get('name', '?')
                        lines_out.append(f"TOOL_USE: {name}")
                    elif btype == 'tool_result':
                        is_err = block.get('is_error', False)
                        if is_err:
                            out_content = block.get('content', '')
                            if isinstance(out_content, list):
                                out_content = ' '.join(
                                    b.get('text','') for b in out_content if b.get('type')=='text'
                                )
                            out_content = str(out_content).strip()[:500]
                            lines_out.append(f"TOOL_ERROR: {out_content}")
                        # else: drop successful tool results (bulk noise)

        elif etype in ('tool_use', 'tool_result', 'text'):
            if etype == 'text':
                text = entry.get('text', '').strip()
                if not text or any(text.startswith(p) for p in SKIP_PREFIXES):
                    continue
                lines_out.append(f"TEXT: {text}")
            elif etype == 'tool_use':
                name = entry.get('name', '?')
                lines_out.append(f"TOOL_USE: {name}")
            elif etype == 'tool_result':
                is_err = entry.get('is_error', False)
                if is_err:
                    out_content = entry.get('content', '')
                    if isinstance(out_content, list):
                        out_content = ' '.join(
                            b.get('text','') for b in out_content if b.get('type')=='text'
                        )
                    out_content = str(out_content).strip()[:500]
                    lines_out.append(f"TOOL_ERROR: {out_content}")

log_text = '\n'.join(lines_out)

with open(dst, 'w') as f:
    f.write(log_text)

print(len(lines_out))
PYEOF

ENTRY_COUNT=$(cat "$NORM_FILE" | wc -l)
CHAR_COUNT=$(wc -c < "$NORM_FILE")
log "Normalized: ${ENTRY_COUNT} lines, ${CHAR_COUNT} chars"

if [[ "$CHAR_COUNT" -lt 50 ]]; then
  log "Transcript appears empty or too short — nothing to process."
  exit 0
fi

# ---------------------------------------------------------------------------
# STEP 2: Extract candidate learnings via LLM
# ---------------------------------------------------------------------------
log "Step 2: Extracting learnings with ollama (model: ${OLLAMA_MODEL})..."

CONV_LOG=$(cat "$NORM_FILE")

EXTRACT_PROMPT="You are an AI assistant that extracts useful learnings from Claude Code session transcripts.

Below is a conversation log from a coding session. Extract learnings that are worth storing as long-term memory.

Focus on:
- Things that broke and how they were fixed
- Configuration or API discoveries
- Architectural decisions and their rationale
- Patterns or approaches that worked well
- User corrections or preferences (e.g. \"user prefers X approach\")

Skip:
- Routine file reads or edits with no insight
- Things that are already obvious
- One-off tasks that won't generalize

Return a JSON object with a \"learnings\" key containing an array of objects:
{\"learnings\": [{\"title\": \"short title (under 10 words)\", \"text\": \"detailed learning as a reference note\", \"tags\": [\"tag1\", \"tag2\"]}]}

If there are no useful learnings, return: {\"learnings\": []}

--- CONVERSATION LOG ---
${CONV_LOG}
--- END ---"

log "Calling ollama for extraction..."
RAW_CANDIDATES=$(ollama_generate "$EXTRACT_PROMPT") || die "Ollama extraction failed"

# Parse and validate the JSON array
CANDIDATES=$(python3 -c "
import json, sys
raw = sys.stdin.read().strip()
# Try to find a JSON array in the response
try:
    data = json.loads(raw)
    if isinstance(data, list):
        # Ensure all items are dicts (not bare strings)
        if all(isinstance(x, dict) for x in data):
            print(json.dumps(data))
            sys.exit(0)
    # Single object with title/text — wrap in array
    if isinstance(data, dict) and 'title' in data and 'text' in data:
        print(json.dumps([data]))
        sys.exit(0)
    # Maybe wrapped in an object with a list of candidate dicts
    if isinstance(data, dict):
        for v in data.values():
            if isinstance(v, list) and len(v) > 0 and isinstance(v[0], dict):
                print(json.dumps(v))
                sys.exit(0)
except Exception:
    pass
# Try to extract array from text
import re
m = re.search(r'(\[.*\])', raw, re.DOTALL)
if m:
    try:
        data = json.loads(m.group(1))
        if isinstance(data, list) and all(isinstance(x, dict) for x in data):
            print(json.dumps(data))
            sys.exit(0)
    except Exception:
        pass
sys.stderr.write('Could not parse candidates JSON from: ' + raw[:200] + '\n')
sys.exit(1)
" <<< "$RAW_CANDIDATES") || die "Failed to parse candidate learnings from LLM response"

echo "$CANDIDATES" > "$CANDIDATES_FILE"

CANDIDATE_COUNT=$(python3 -c "import json,sys; print(len(json.load(open(sys.argv[1]))))" "$CANDIDATES_FILE")
log "Extracted ${CANDIDATE_COUNT} candidate learnings"

if [[ "$CANDIDATE_COUNT" -eq 0 ]]; then
  log "No learnings to process."
  echo "Summary: 0 extracted, 0 stored, 0 updated, 0 skipped"
  exit 0
fi

# ---------------------------------------------------------------------------
# STEP 3: Search for existing memory overlaps
# ---------------------------------------------------------------------------
log "Step 3: Searching for existing memory overlaps..."

SEARCH_RESULTS_FILE="${TMP_PREFIX}-search-results.json"

python3 - "$CANDIDATES_FILE" "$SEARCH_RESULTS_FILE" "$SOCKET_PATH" "$QDRANT_URL" "$QDRANT_API_KEY" "$COLLECTION_NAME" "$PROJECT" <<'PYEOF'
import json, sys, socket as sock_mod

candidates_path = sys.argv[1]
results_path = sys.argv[2]
socket_path = sys.argv[3]
qdrant_url = sys.argv[4]
qdrant_api_key = sys.argv[5]
collection_name = sys.argv[6]
project = sys.argv[7]

def daemon_call(method, params):
    params['qdrantUrl'] = qdrant_url
    params['qdrantApiKey'] = qdrant_api_key
    params['collectionName'] = collection_name
    s = sock_mod.socket(sock_mod.AF_UNIX, sock_mod.SOCK_STREAM)
    s.connect(socket_path)
    s.settimeout(30)
    req = json.dumps({'jsonrpc':'2.0','id':str(hash(method) % 99999),'method':method,'params':params}) + '\n'
    s.sendall(req.encode())
    buf = b''
    while b'\n' not in buf:
        chunk = s.recv(65536)
        if not chunk:
            break
        buf += chunk
    s.close()
    return json.loads(buf.decode().strip())

candidates = json.load(open(candidates_path))
all_results = []

for candidate in candidates:
    query = candidate.get('title', '') + ' ' + candidate.get('text', '')[:100]
    try:
        resp = daemon_call('search_memory', {'query': query, 'limit': 3, 'project': project})
        matches = resp.get('result', {}).get('results', [])
    except Exception as e:
        sys.stderr.write(f'Search failed for "{candidate["title"]}": {e}\n')
        matches = []

    all_results.append({
        'candidate': candidate,
        'matches': [
            {'id': m['id'], 'title': m.get('title',''), 'text': m['text'][:200], 'score': m['score']}
            for m in matches
        ],
    })

with open(results_path, 'w') as f:
    json.dump(all_results, f, indent=2)

print(f'Searched {len(candidates)} candidates')
PYEOF

log "Search complete."

# ---------------------------------------------------------------------------
# STEP 4: Decide store / update / skip
# ---------------------------------------------------------------------------
log "Step 4: Deciding store/update/skip with LLM..."

SEARCH_CONTEXT=$(cat "$SEARCH_RESULTS_FILE")

DECIDE_PROMPT="You are deciding whether to store new memories, update existing ones, or skip duplicates.

For each candidate learning below, I have searched the memory store and found the closest existing memories.

For each candidate, decide:
- STORE: this is genuinely new information worth storing
- UPDATE: this overlaps significantly with an existing memory — merge them into a richer memory
- SKIP: this is already covered by existing memories or is not worth storing

Return a JSON object with a \"learnings\" key containing an array with one object per candidate:
- For STORE: {\"action\": \"store\", \"title\": \"...\", \"text\": \"...\", \"tags\": [...]}
- For UPDATE: {\"action\": \"update\", \"id\": \"existing-id\", \"title\": \"updated title\", \"text\": \"merged text combining old and new\", \"tags\": [...]}
- For SKIP: {\"action\": \"skip\", \"title\": \"...\", \"reason\": \"why skipping\"}

--- CANDIDATES WITH EXISTING MEMORY MATCHES ---
${SEARCH_CONTEXT}
--- END ---"

log "Calling ollama for store/update/skip decisions..."
RAW_DECISIONS=$(ollama_generate "$DECIDE_PROMPT") || die "Ollama decision step failed"

DECISIONS=$(python3 -c "
import json, sys
raw = sys.stdin.read().strip()
try:
    data = json.loads(raw)
    if isinstance(data, list):
        if all(isinstance(x, dict) for x in data):
            print(json.dumps(data))
            sys.exit(0)
    # Single decision object — wrap in array
    if isinstance(data, dict) and 'action' in data:
        print(json.dumps([data]))
        sys.exit(0)
    if isinstance(data, dict):
        for v in data.values():
            if isinstance(v, list) and len(v) > 0 and isinstance(v[0], dict):
                print(json.dumps(v))
                sys.exit(0)
except Exception:
    pass
import re
m = re.search(r'(\[.*\])', raw, re.DOTALL)
if m:
    try:
        data = json.loads(m.group(1))
        if isinstance(data, list) and all(isinstance(x, dict) for x in data):
            print(json.dumps(data))
            sys.exit(0)
    except Exception:
        pass
sys.stderr.write('Could not parse decisions JSON from: ' + raw[:200] + '\n')
sys.exit(1)
" <<< "$RAW_DECISIONS") || die "Failed to parse decisions from LLM response"

echo "$DECISIONS" > "$DECISIONS_FILE"
log "Decisions parsed."

# ---------------------------------------------------------------------------
# STEP 5: Execute actions
# ---------------------------------------------------------------------------
log "Step 5: Executing actions..."

COUNT_STORED=0
COUNT_UPDATED=0
COUNT_SKIPPED=0

DECISION_COUNT=$(python3 -c "import json,sys; print(len(json.load(open(sys.argv[1]))))" "$DECISIONS_FILE")

for i in $(seq 0 $((DECISION_COUNT - 1))); do
  ACTION=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d[$i]['action'])" "$DECISIONS_FILE")
  TITLE=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d[$i].get('title','(no title)'))" "$DECISIONS_FILE")

  case "$ACTION" in
    store)
      TEXT=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d[$i].get('text',''))" "$DECISIONS_FILE")
      TAGS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(json.dumps(d[$i].get('tags',[])))" "$DECISIONS_FILE")

      if [[ "$DRY_RUN" == "true" ]]; then
        log "[DRY-RUN] STORE: $TITLE"
      else
        log "STORE: $TITLE"
        PARAMS=$(python3 -c "
import json, sys
print(json.dumps({'text': sys.argv[1], 'title': sys.argv[2], 'tags': json.loads(sys.argv[3]), 'project': sys.argv[4], 'agent': 'ingest-transcript'}))
" "$TEXT" "$TITLE" "$TAGS" "$PROJECT")
        RESP=$(daemon_rpc "store_memory" "$PARAMS")
        NEW_ID=$(echo "$RESP" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('result',{}).get('id','?'))" 2>/dev/null || echo "?")
        log "  -> Stored with ID: $NEW_ID"
      fi
      COUNT_STORED=$((COUNT_STORED + 1))
      ;;

    update)
      ID=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d[$i].get('id',''))" "$DECISIONS_FILE")
      TEXT=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d[$i].get('text',''))" "$DECISIONS_FILE")
      TAGS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(json.dumps(d[$i].get('tags',[])))" "$DECISIONS_FILE")

      if [[ "$DRY_RUN" == "true" ]]; then
        log "[DRY-RUN] UPDATE id=$ID: $TITLE"
      else
        log "UPDATE id=$ID: $TITLE"
        PARAMS=$(python3 -c "
import json, sys
print(json.dumps({'id': sys.argv[1], 'text': sys.argv[2], 'title': sys.argv[3], 'tags': json.loads(sys.argv[4]), 'project': sys.argv[5]}))
" "$ID" "$TEXT" "$TITLE" "$TAGS" "$PROJECT")
        RESP=$(daemon_rpc "update_memory" "$PARAMS")
        log "  -> Updated"
      fi
      COUNT_UPDATED=$((COUNT_UPDATED + 1))
      ;;

    skip)
      REASON=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d[$i].get('reason',''))" "$DECISIONS_FILE")
      log "SKIP: $TITLE — $REASON"
      COUNT_SKIPPED=$((COUNT_SKIPPED + 1))
      ;;

    *)
      log "Unknown action '$ACTION' for: $TITLE — skipping"
      COUNT_SKIPPED=$((COUNT_SKIPPED + 1))
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "Summary: ${CANDIDATE_COUNT} extracted, ${COUNT_STORED} stored, ${COUNT_UPDATED} updated, ${COUNT_SKIPPED} skipped"
