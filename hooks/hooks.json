{
  "description": "Injects the shared memory context-capture prompt every fifth assistant turn so agents update existing memories and store new architecture/workflow learnings.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=\"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; test -n \"$root\"; exec \"$root/bin/shared-agent-memory\" --memory-turn-hook'",
            "timeout": 10,
            "statusMessage": "Checking shared memory updates"
          }
        ]
      }
    ]
  }
}
